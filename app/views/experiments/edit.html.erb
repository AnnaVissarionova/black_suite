<div class="min-h-screen bg-gray-50 py-6 px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl mx-auto">
    <nav class="mb-8 text-sm">
      <%= link_to 'Проекты', projects_path, class: 'text-primary-600 hover:text-primary-700' %> ›
      <%= link_to @project.name, project_path(@project), class: 'text-primary-600 hover:text-primary-700' %> ›
      <%= link_to @experiment.name, experiment_view_project_path(@project, experiment_id: @experiment.id), class: 'text-primary-600 hover:text-primary-700' %> ›
      <span class="text-gray-600 font-medium">Редактирование</span>
    </nav>

    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-800">Редактировать эксперимент</h1>
      <p class="mt-2 text-gray-500 text-sm">Измените информацию об эксперименте «<%= @experiment.name %>»</p>
    </div>

    <div class="bg-white shadow-sm rounded-xl border border-gray-100 p-8">
      <%= form_with model: [@project, @experiment], multipart: true, class: 'space-y-6' do |f| %>
        <%= render 'shared/error_messages', object: f.object %>

        <div>
          <%= f.label :name, 'Название эксперимента', class: 'block text-sm font-medium text-gray-700 mb-2' %>
          <%= f.text_field :name,
                          required: true,
                          class: 'w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition' %>
        </div>

        <div>
          <%= f.label :description, 'Описание', class: 'block text-sm font-medium text-gray-700 mb-2' %>
          <%= f.text_area :description,
                         rows: 4,
                         class: 'w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition resize-none' %>
        </div>

        <div class="border-t border-gray-100 pt-6">
          <h3 class="text-sm font-medium text-gray-700 mb-4">Данные результатов</h3>

          <%
            latest_json = @experiment.json_results.order(created_at: :desc).first
            has_json = latest_json.present?
          %>

          <% if has_json %>
            <div class="bg-primary-50 border border-primary-100 rounded-lg p-4 mb-4">
              <div class="flex items-center justify-between">
                <div class="flex items-center">
                  <svg class="h-5 w-5 text-primary-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  <div>
                    <p class="text-sm font-medium text-primary-700">Текущий JSON файл</p>
                    <p class="text-xs text-primary-500"><%= ru_time_ago_in_words(latest_json.created_at) %></p>
                  </div>
                </div>
                <%= link_to download_json_project_experiment_path(@project, @experiment),
                            class: "text-xs px-3 py-1.5 bg-white border border-primary-200 rounded-lg text-primary-600 hover:bg-primary-50 transition" do %>
                  Скачать
                <% end %>
              </div>
            </div>
          <% end %>

          <div class="flex justify-center px-6 pt-5 pb-6 border-2 border-gray-200 border-dashed rounded-lg hover:border-primary-300 transition cursor-pointer"
               id="json-dropzone">
            <div class="space-y-1 text-center">
              <svg class="mx-auto h-10 w-10 text-gray-300" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02"
                      stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div class="flex text-sm text-gray-500 justify-center">
                <span class="font-medium text-primary-600"><%= has_json ? 'Заменить файл' : 'Загрузите файл' %></span>
                <p class="pl-1">или перетащите сюда</p>
              </div>
              <p class="text-xs text-gray-400">JSON файлы до 10MB</p>
            </div>
          </div>

          <%= file_field_tag :json_file,
                            accept: '.json',
                            class: 'hidden',
                            id: 'json_file_input' %>

          <div id="new-file-preview" class="hidden mt-4 bg-green-50 border border-green-100 rounded-lg p-4">
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <svg class="h-5 w-5 text-green-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <p id="new-file-name" class="text-sm font-medium text-green-700"></p>
                  <p id="new-file-size" class="text-xs text-green-500"></p>
                </div>
              </div>
              <button type="button" id="clear-new-file" class="text-green-500 hover:text-green-700">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-end space-x-4 pt-4 border-t border-gray-100">
          <%= link_to 'Отмена', project_path(@project),
                      class: 'px-4 py-2 border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 transition' %>
          <%= f.submit 'Сохранить изменения',
                      class: 'px-6 py-2 bg-primary-500 text-white rounded-lg hover:bg-primary-600 transition font-medium cursor-pointer' %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  (function() {
    const dropzone = document.getElementById('json-dropzone');
    const fileInput = document.getElementById('json_file_input');
    const preview = document.getElementById('new-file-preview');
    const fileName = document.getElementById('new-file-name');
    const fileSize = document.getElementById('new-file-size');
    const clearBtn = document.getElementById('clear-new-file');

    if (!dropzone || !fileInput) return;

    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
      dropzone.addEventListener(eventName, e => {
        e.preventDefault();
        e.stopPropagation();
      });
    });

    ['dragenter', 'dragover'].forEach(eventName => {
      dropzone.addEventListener(eventName, () => {
        dropzone.classList.add('border-primary-400', 'bg-primary-50');
      });
    });

    ['dragleave', 'drop'].forEach(eventName => {
      dropzone.addEventListener(eventName, () => {
        dropzone.classList.remove('border-primary-400', 'bg-primary-50');
      });
    });

    dropzone.addEventListener('drop', e => {
      const files = e.dataTransfer.files;
      if (files.length > 0) {
        const dataTransfer = new DataTransfer();
        dataTransfer.items.add(files[0]);
        fileInput.files = dataTransfer.files;
        handleFile(files[0]);
      }
    });

    dropzone.addEventListener('click', () => fileInput.click());

    fileInput.addEventListener('change', function() {
      if (this.files.length > 0) {
        handleFile(this.files[0]);
      }
    });

    function handleFile(file) {
      if (!file.name.toLowerCase().endsWith('.json')) {
        alert('Пожалуйста, загрузите файл в формате JSON');
        fileInput.value = '';
        return;
      }

      if (file.size > 10 * 1024 * 1024) {
        alert('Файл слишком большой. Максимальный размер: 10MB');
        fileInput.value = '';
        return;
      }

      fileName.textContent = file.name;
      fileSize.textContent = (file.size / 1024).toFixed(2) + ' KB';
      preview.classList.remove('hidden');
    }

    clearBtn?.addEventListener('click', () => {
      fileInput.value = '';
      preview.classList.add('hidden');
    });
  })();
</script>
