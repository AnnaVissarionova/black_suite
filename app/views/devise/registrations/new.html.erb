<div class="min-h-screen bg-gradient-to-br from-primary-50 to-primary-100 flex items-center justify-center px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-2">
    <div class="text-center">
      <div class="flex justify-center">
        <div class="h-6 w-12 text-primary-600">
          <svg viewBox="0 0 48 48" fill="currentColor">
            <polygon points="10.807 14.858 5.5 24.053 10.777 33.195 16.084 24 10.807 14.858" fill="#7c3aed" stroke="#6d28d9" stroke-width="0.5"></polygon>
            <polygon points="16.084 24 10.777 33.195 21.331 33.195 26.639 24 16.084 24" fill="#8b5cf6" stroke="#6d28d9" stroke-width="0.5"></polygon>
            <polygon points="10.807 14.858 16.084 24 26.639 24 21.361 14.858 10.807 14.858" fill="#a78bfa" stroke="#6d28d9" stroke-width="0.5"></polygon>
            <polygon points="26.669 5.662 21.361 14.858 26.639 24 31.946 14.805 26.669 5.662" fill="#7c3aed" stroke="#6d28d9" stroke-width="0.5"></polygon>
            <polygon points="31.946 14.805 26.639 24 37.193 24 42.5 14.805 31.946 14.805" fill="#8b5cf6" stroke="#6d28d9" stroke-width="0.5"></polygon>
            <polygon points="26.669 5.662 31.946 14.805 42.5 14.805 37.223 5.662 26.669 5.662" fill="#a78bfa" stroke="#6d28d9" stroke-width="0.5"></polygon>
            <polygon points="26.639 24 21.331 33.195 26.608 42.338 31.916 33.142 26.639 24" fill="#7c3aed" stroke="#6d28d9" stroke-width="0.5"></polygon>
            <polygon points="31.916 33.142 26.608 42.338 37.163 42.338 42.47 33.142 31.916 33.142" fill="#8b5cf6" stroke="#6d28d9" stroke-width="0.5"></polygon>
            <polygon points="26.639 24 31.916 33.142 42.47 33.142 37.193 24 26.639 24" fill="#a78bfa" stroke="#6d28d9" stroke-width="0.5"></polygon>
          </svg>
        </div>
      </div>
      <h2 class="mt-4 text-2xl font-extrabold text-gray-900">BlackSuite</h2>
      <p class="mt-1 text-sm text-gray-600">Войдите в свой аккаунт</p>
    </div>

    <div class="bg-white rounded-lg shadow-xl p-6">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: 'space-y-4' }) do |f| %>
        <div>
          <%= f.label :email, 'Email', class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.email_field :email,
                            autofocus: true,
                            autocomplete: 'email',
                            class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition' %>
        </div>

        <div>
          <%= f.label :password, 'Пароль', class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.password_field :password,
                               autocomplete: 'current-password',
                               class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition' %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center">
            <%= f.check_box :remember_me, class: 'h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded' %>
            <%= f.label :remember_me, 'Запомнить меня', class: 'ml-2 block text-sm text-gray-900' %>
          </div>
        <% end %>

        <div>
          <%= f.submit 'Войти',
                       class: 'w-full flex justify-center py-2 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition' %>
        </div>
      <% end %>

      <div class="mt-4 text-center text-sm space-y-2">
        <p class="text-gray-600">
          Нет аккаунта?
          <%= link_to 'Зарегистрироваться', new_registration_path(resource_name),
                      class: 'font-medium text-primary-600 hover:text-primary-500' %>
        </p>

      </div>
    </div>
  </div>
</div>
