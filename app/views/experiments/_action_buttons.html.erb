<div class="flex flex-wrap gap-2">
  <%= render 'experiments/sharing_settings', experiment: experiment, project: project %>

  <%= link_to edit_project_experiment_path(project, experiment),
              class: "inline-flex items-center justify-center px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 hover:border-primary-300 transition-all shadow-sm",
              title: "Редактировать эксперимент" do %>
    <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
    </svg>
    Редактировать
  <% end %>

  <% if json_results_count && json_results_count > 0 %>
    <%= link_to download_json_project_experiment_path(project, experiment),
                data: { turbo: false },
                class: "inline-flex items-center justify-center px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 hover:border-primary-300 transition-all shadow-sm",
                title: "Скачать результаты JSON" do %>
      <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
      </svg>
      Скачать JSON
    <% end %>
  <% end %>

  <%= link_to project_experiment_path(project, experiment),
              data: {
                turbo_method: :delete,
                turbo_confirm: "Удалить эксперимент «#{experiment.name}»? Это действие необратимо."
              },
              class: "inline-flex items-center justify-center px-3 py-1.5 bg-white border border-red-200 rounded-lg text-sm font-medium text-red-500 hover:bg-red-50 hover:border-red-300 transition-all shadow-sm",
              title: "Удалить эксперимент" do %>
    <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
    </svg>
    Удалить
  <% end %>
</div>
