<div class="min-h-screen bg-gray-50 py-6 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto">
    <nav class="mb-8 text-sm">
      <%= link_to 'Проекты', projects_path, class: 'text-primary-600 hover:text-primary-700' %> ›
      <%= link_to @project.name, project_path(@project), class: 'text-primary-600 hover:text-primary-700' %> ›
      <span class="text-gray-600 font-medium">Редактирование</span>
    </nav>

    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-800">Редактировать проект</h1>
      <p class="mt-2 text-gray-500 text-sm">Измените информацию о проекте «<%= @project.name %>»</p>
    </div>

    <div class="bg-white shadow-sm rounded-xl border border-gray-200 px-8 py-4">
      <%= form_with model: @project, class: 'space-y-6' do |f| %>
        <%= render 'shared/error_messages', object: f.object %>

        <div>
          <%= f.label :name, 'Название проекта', class: 'block text-sm font-medium text-gray-700 mb-2' %>
          <%= f.text_field :name,
                          required: true,
                          class: 'w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition' %>
        </div>

        <div>
          <%= f.label :description, 'Описание', class: 'block text-sm font-medium text-gray-700 mb-2' %>
          <%= f.text_area :description,
                         rows: 6,
                         class: 'w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-400 focus:border-primary-400 transition resize-none' %>
        </div>

        <div class="flex items-center justify-end space-x-4 pt-6 pb-4 border-t border-gray-100">
          <%= link_to 'Отмена', project_path(@project),
                      class: 'px-4 py-2 border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 transition' %>
          <%= f.submit 'Сохранить изменения',
                      class: 'px-6 py-2 bg-primary-500 text-white rounded-lg hover:bg-primary-600 transition font-medium cursor-pointer' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
