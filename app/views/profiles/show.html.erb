<div class="h-full pt-6">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Заголовок -->
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-gray-800">Личный кабинет</h1>
      <p class="text-gray-500 mt-1">Управление профилем и API доступом</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Левая колонка -->
      <div class="space-y-6">

        <!-- Информация о пользователе -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-300 overflow-hidden">
          <div class="px-6 py-3 border-b border-gray-100 bg-gray-50">
            <h2 class="text-lg font-semibold text-gray-700">Информация о пользователе</h2>
          </div>

          <div class="p-6">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
              <!-- Левая подколонка -->
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-gray-500 mb-1">Email</label>
                  <p class="text-gray-800 flex items-center">
                    <svg class="h-4 w-4 mr-2 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    <span class="break-all"><%= @user.email %></span>
                  </p>
                </div>

                <div>
                  <label class="block text-sm font-medium text-gray-500 mb-1">ID пользователя</label>
                  <p class="text-gray-800 flex items-center">
                    <svg class="h-4 w-4 mr-2 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    <%= @user.id %>
                  </p>
                </div>
              </div>

              <!-- Правая подколонка -->
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-gray-500 mb-1">Дата регистрации</label>
                  <p class="text-gray-800 flex items-center">
                    <svg class="h-4 w-4 mr-2 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <%= @user.created_at.strftime('%d.%m.%Y %H:%M') %>
                  </p>
                </div>

                <div>
                  <label class="block text-sm font-medium text-gray-500 mb-1">Количество проектов</label>
                  <p class="text-gray-800 flex items-center">
                    <svg class="h-4 w-4 mr-2 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                    <%= pluralize(@user.projects.count, 'проект', 'проекта', 'проектов') %>
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Смена пароля -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-300 overflow-hidden">
          <button onclick="togglePasswordCard()"
                  type="button"
                  class="w-full px-6 py-3 flex items-center justify-between bg-gray-50 transition">
            <div class="text-left">
              <h2 class="text-lg font-semibold text-gray-700">Смена пароля</h2>
            </div>
            <svg id="passwordArrow" class="h-5 w-5 text-gray-400 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <div id="passwordContent" class="hidden border-t border-gray-100">
            <div class="px-6 mb-4">
              <%= form_with model: @user, url: update_password_profile_path, method: :patch, local: true, class: "space-y-4" do |f| %>
                <div>
                  <%= f.label :current_password, "Текущий пароль", class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <%= f.password_field :current_password, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent", required: true %>
                </div>

                <div>
                  <%= f.label :password, "Новый пароль", class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <%= f.password_field :password, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent", required: true %>
                  <p class="text-xs text-gray-500 mt-1">Минимум 6 символов</p>
                </div>

                <div>
                  <%= f.label :password_confirmation, "Подтверждение нового пароля", class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <%= f.password_field :password_confirmation, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent", required: true %>
                </div>

                <%= f.submit "Сменить пароль", class: "w-full px-4 py-2 bg-primary-500 text-white rounded-lg hover:bg-primary-600 transition font-medium cursor-pointer" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Правая колонка -->
      <div class="space-y-6">

        <div class="bg-white rounded-xl shadow-sm border border-gray-300 overflow-hidden">
          <div class="px-6 py-3 border-b border-gray-100 bg-gray-50">
            <h2 class="text-lg font-semibold text-gray-700">API Токен</h2>
          </div>

          <div class="px-6 py-4">
            <div class="mb-4">
              <label class="block text-sm font-medium text-gray-500 mb-2">Ваш API токен</label>
              <div class="flex items-center space-x-2">
                <code class="flex-1 px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm font-mono text-gray-700 break-all">
                  <%= @user.api_token || 'Токен не создан' %>
                </code>

                <% if @user.api_token.present? %>
                  <button onclick="copyToClipboard()"
                          type="button"
                          class="px-3 py-2 bg-gray-100 hover:bg-gray-200 rounded-lg transition"
                          title="Скопировать токен">
                    <svg class="h-5 w-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                  </button>
                <% end %>
              </div>
            </div>

            <!-- Кнопка перегенерации -->
            <%= form_tag regenerate_token_profile_path, method: :post, local: true, class: "w-full" do %>
              <button type="submit"
                      class="w-full px-4 py-2 bg-primary-500 text-white rounded-lg hover:bg-primary-600 transition font-medium flex items-center justify-center"
                      data-confirm="Внимание! После перегенерации токена старый токен перестанет работать. Все API запросы нужно будет использовать с новым токеном. Продолжить?">
                <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Перегенерировать API токен
              </button>
            <% end %>

            <p class="text-xs text-gray-400 mt-3 flex items-start">
                При перегенерации токена старый токен перестанет работать. Убедитесь, что обновите его во всех API запросах.
            </p>
          </div>
        </div>

        <!-- Пример использования API -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-300 overflow-hidden">
          <div class="px-6 py-3 border-b border-gray-100 bg-gray-50">
            <h2 class="text-lg font-semibold text-gray-700">Пример использования API</h2>
          </div>

          <div class="px-6 py-4">
            <div class="bg-gray-800 rounded-lg p-4 overflow-x-auto mb-4">
              <pre class="text-gray-200 text-xs font-mono"><code>curl -X POST http://localhost:3000/api/add_experiment_result \
  -H "Authorization: Bearer <%= @user.api_token %>" \
  -F "project_id=1" \
  -F "json_file=@absolute/path/to/experiment.json" \
  -F "experiment_name=Новый эксперимент"</code></pre>
            </div>

            <div class="bg-blue-50 border border-blue-200 rounded-lg p-3">
              <p class="text-sm text-blue-700 flex items-center">
                <svg class="h-4 w-4 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                ID проекта можно посмотреть в его карточке.<br>
                Название эксперимента - необязательный параметр.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
    function togglePasswordCard() {
        const content = document.getElementById('passwordContent');
        const arrow = document.getElementById('passwordArrow');

        if (content.classList.contains('hidden')) {
            content.classList.remove('hidden');
            arrow.style.transform = 'rotate(180deg)';
        } else {
            content.classList.add('hidden');
            arrow.style.transform = 'rotate(0deg)';
        }
    }

    function copyToClipboard() {
        const token = '<%= @user.api_token %>';
        navigator.clipboard.writeText(token).then(() => {
            const notification = document.createElement('div');
            notification.className = 'fixed top-4 right-4 bg-green-500 text-white px-4 py-2 rounded-lg shadow-lg text-sm z-50';
            notification.innerHTML = 'Токен скопирован!';
            document.body.appendChild(notification);
            setTimeout(() => notification.remove(), 2000);
        });
    }
</script>
