<% if policy(@project).update? %>
  <button onclick="openProjectShareModal()"
          class="inline-flex items-center justify-center px-4 py-2 bg-white border-2 border-primary-300 rounded-full text-sm font-medium text-primary-700 hover:bg-primary-50 transition-all shadow-sm hover:shadow">
    <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
    </svg>
    Поделиться проектом
  </button>

  <!-- модальное окно для шаринга проекта -->
  <div id="projectShareModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-2xl max-w-xl w-full max-h-[90vh] overflow-y-auto" onclick="event.stopPropagation()">
      <!-- Заголовок -->
      <div class="flex items-center justify-between p-6 border-b border-gray-200">
        <h3 class="text-xl font-semibold text-gray-900 flex items-center">
          <svg class="h-6 w-6 mr-2 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
          </svg>
          Поделиться проектом
        </h3>
        <button onclick="closeProjectShareModal()" class="text-gray-400 hover:text-gray-600 transition">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div id="project-share-content" class="p-6">
      </div>
    </div>
  </div>

  <script>
      const csrfToken = document.querySelector('meta[name="csrf-token"]').content;

      function openProjectShareModal() {
          document.getElementById('projectShareModal').classList.remove('hidden');
          document.body.style.overflow = 'hidden';
          loadProjectSharingContent();
      }

      function closeProjectShareModal() {
          document.getElementById('projectShareModal').classList.add('hidden');
          document.body.style.overflow = 'auto';
      }

      function loadProjectSharingContent() {
          const contentDiv = document.getElementById('project-share-content');
          contentDiv.innerHTML = `
              <div class="text-center py-8">
                  <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600 mb-3"></div>
                  <p class="text-gray-500">Загрузка...</p>
              </div>
          `;

          fetch('<%= sharing_project_path(@project) %>', {
              headers: {
                  'Accept': 'application/json',
                  'X-CSRF-Token': csrfToken
              }
          })
              .then(response => response.json())
              .then(data => {
                  updateProjectSharingContent(data);
              })
              .catch(error => {
                  console.error('Ошибка загрузки:', error);
                  contentDiv.innerHTML = `
                  <div class="text-center py-8">
                      <svg class="h-12 w-12 text-red-400 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <p class="text-gray-700">Ошибка загрузки данных</p>
                      <button onclick="loadProjectSharingContent()" class="mt-4 px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700">
                          Повторить
                      </button>
                  </div>
              `;
              });
      }

      function updateProjectSharingContent(data) {
          const contentDiv = document.getElementById('project-share-content');

          console.log('Updating content with data:', data);

          if (data.shared && data.share_mode === 'view' && data.share_token) {
              contentDiv.innerHTML = `
            <div class="space-y-6">
                <div class="p-4 bg-green-50 border border-green-200 rounded-lg">
                    <div class="flex items-start justify-between mb-3">
                        <div class="flex items-center">
                            <svg class="h-5 w-5 text-green-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span class="font-medium text-green-900">Доступ по ссылке активен</span>
                        </div>
                        <button onclick="disableProjectSharing()" class="text-sm text-red-600 hover:text-red-800 font-medium">
                            Отключить
                        </button>
                    </div>

                    <p class="text-sm text-gray-600 mb-3">
                        Пользователи с этой ссылкой могут <strong>просматривать</strong> проект и все эксперименты в нём.
                    </p>

                    <label class="block text-sm font-medium text-gray-700 mb-2">Ссылка для просмотра проекта:</label>
                    <div class="flex items-center space-x-2">
                        <input type="text"
                               value="${data.share_url || ''}"
                               readonly
                               id="project-share-link"
                               class="flex-1 px-3 py-2 border border-gray-300 rounded-lg bg-white text-sm font-mono">
                        <button type="button"
                                onclick="copyProjectShareLink()"
                                class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition font-medium text-sm whitespace-nowrap">
                            <svg class="h-4 w-4 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                            </svg>
                        </button>
                    </div>

                    <div class="mt-3 flex items-center justify-between">
                        <button onclick="regenerateProjectToken()"
                                class="text-sm text-gray-600 hover:text-gray-900 flex items-center">
                            <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                            </svg>
                            Обновить ссылку
                        </button>

                        <span id="project-copy-success-message" class="hidden text-sm text-green-600 font-medium">
                            Скопировано!
                        </span>
                    </div>
                </div>
            </div>

            <!-- Футер -->
            <div class="flex items-center justify-end gap-3 pt-6 mt-6 border-t border-gray-200">
                <button type="button"
                        onclick="closeProjectShareModal()"
                        class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-100 transition font-medium">
                    Закрыть
                </button>
            </div>
        `;
          } else {
              contentDiv.innerHTML = `
            <div class="space-y-6">
                <div class="p-4 bg-gray-50 border border-gray-200 rounded-lg">
                    <div class="flex items-start mb-4">
                        <svg class="h-6 w-6 text-gray-400 mr-3 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <div>
                            <p class="text-sm text-gray-700 font-medium mb-2">
                                Создайте ссылку для общего доступа к проекту
                            </p>
                            <p class="text-xs text-gray-500">
                                Пользователи с ссылкой смогут <strong>просматривать</strong> проект и все эксперименты в нём.
                                Редактирование и удаление будут недоступны.
                            </p>
                        </div>
                    </div>

                    <button onclick="enableProjectSharing()"
                            class="w-full inline-flex items-center justify-center px-4 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition font-medium">
                        <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                        </svg>
                        Создать ссылку для доступа
                    </button>
                </div>
            </div>

            <div class="flex items-center justify-end gap-3 pt-6 mt-6 border-t border-gray-200">
                <button type="button"
                        onclick="closeProjectShareModal()"
                        class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-100 transition font-medium">
                    Закрыть
                </button>
            </div>
        `;
          }
      }

      function enableProjectSharing() {
          const contentDiv = document.getElementById('project-share-content');
          contentDiv.innerHTML = `
        <div class="text-center py-8">
            <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600 mb-3"></div>
            <p class="text-gray-500">Создание ссылки...</p>
        </div>
    `;

          fetch('<%= update_sharing_project_path(@project) %>', {
              method: 'PATCH',
              headers: {
                  'X-CSRF-Token': csrfToken,
                  'Accept': 'application/json',
                  'Content-Type': 'application/json'
              },
              body: JSON.stringify({ share_mode: 'view' })
          })
            .then(response => {
                console.log('Enable sharing response status:', response.status);
                if (!response.ok) {
                    return response.json().then(data => {
                        throw new Error(data.error || `HTTP error! status: ${response.status}`);
                    });
                }
                return response.json();
            })
            .then(data => {
                console.log('Enable sharing data:', data);
                if (data.success) {
                    loadProjectSharingContent();
                } else {
                    alert(data.error || 'Ошибка при создании ссылки');
                    loadProjectSharingContent();
                }
            })
            .catch(error => {
                console.error('Enable sharing error:', error);
                alert('Ошибка при создании ссылки: ' + error.message);
                loadProjectSharingContent();
            });
      }

      function disableProjectSharing() {
          if (!confirm('Отключить доступ по ссылке? Пользователи больше не смогут просматривать проект.')) return;

          const contentDiv = document.getElementById('project-share-content');
          contentDiv.innerHTML = `
        <div class="text-center py-8">
            <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600 mb-3"></div>
            <p class="text-gray-500">Отключение доступа...</p>
        </div>
    `;

          fetch('<%= update_sharing_project_path(@project) %>', {
              method: 'PATCH',
              headers: {
                  'X-CSRF-Token': csrfToken,
                  'Accept': 'application/json',
                  'Content-Type': 'application/json'
              },
              body: JSON.stringify({ share_mode: 'private' })
          })
            .then(response => {
                console.log('Disable sharing response status:', response.status);
                if (!response.ok) {
                    return response.json().then(data => {
                        throw new Error(data.error || `HTTP error! status: ${response.status}`);
                    });
                }
                return response.json();
            })
            .then(data => {
                console.log('Disable sharing data:', data);
                if (data.success) {
                    loadProjectSharingContent();
                } else {
                    alert(data.error || 'Ошибка при отключении доступа');
                    loadProjectSharingContent();
                }
            })
            .catch(error => {
                console.error('Disable sharing error:', error);
                alert('Ошибка при отключении доступа: ' + error.message);
                loadProjectSharingContent();
            });
      }

      function regenerateProjectToken() {
          if (!confirm('Текущая ссылка перестанет работать. Создать новую ссылку?')) return;

          const contentDiv = document.getElementById('project-share-content');
          contentDiv.innerHTML = `
        <div class="text-center py-8">
            <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600 mb-3"></div>
            <p class="text-gray-500">Обновление ссылки...</p>
        </div>
    `;

          fetch('<%= regenerate_token_project_path(@project) %>', {
              method: 'POST',
              headers: {
                  'X-CSRF-Token': csrfToken,
                  'Accept': 'application/json'
              }
          })
            .then(response => {
                console.log('Regenerate token response status:', response.status);
                if (!response.ok) {
                    return response.json().then(data => {
                        throw new Error(data.error || `HTTP error! status: ${response.status}`);
                    });
                }
                return response.json();
            })
            .then(data => {
                console.log('Regenerate token data:', data);
                if (data.success) {
                    loadProjectSharingContent();
                } else {
                    alert(data.error || 'Ошибка при обновлении ссылки');
                    loadProjectSharingContent();
                }
            })
            .catch(error => {
                console.error('Regenerate token error:', error);
                alert('Ошибка при обновлении ссылки: ' + error.message);
                loadProjectSharingContent();
            });
      }

      function copyProjectShareLink() {
          const input = document.getElementById('project-share-link');
          if (!input) return;

          input.select();
          input.setSelectionRange(0, 99999);

          try {
              document.execCommand('copy');

              const successMsg = document.getElementById('project-copy-success-message');
              if (successMsg) {
                  successMsg.classList.remove('hidden');
                  setTimeout(() => {
                      successMsg.classList.add('hidden');
                  }, 2000);
              }
          } catch (err) {
              console.error('Ошибка копирования:', err);
              alert('Не удалось скопировать ссылку');
          }
      }

      document.getElementById('projectShareModal')?.addEventListener('click', function(e) {
          if (e.target === this) {
              closeProjectShareModal();
          }
      });

      document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') {
              closeProjectShareModal();
          }
      });
  </script>
<% end %>