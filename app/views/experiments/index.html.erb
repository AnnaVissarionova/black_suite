<div class="py-10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <nav class="mb-8 text-sm">
      <%= link_to 'Проекты', projects_path, class: 'text-primary-600 hover:text-primary-800' %> ›
      <%= link_to @project.name, project_path(@project), class: 'text-primary-600 hover:text-primary-800' %> ›
      <span class="text-gray-600 font-medium">Эксперименты</span>
    </nav>

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Эксперименты</h1>
        <p class="text-gray-600 mt-2">Проект «<%= @project.name %>»</p>
      </div>

      <%= link_to 'Новый эксперимент', new_project_experiment_path(@project),
                  class: 'inline-flex items-center px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition font-medium' %>
    </div>

    <% if @experiments.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @experiments.each do |experiment| %>
          <div class="bg-white rounded-lg shadow hover:shadow-lg transition-all p-6 border-l-4 border-primary-500">
            <div class="flex justify-between items-start mb-2">
              <h3 class="text-lg font-semibold text-gray-900 flex-1">
                <%= link_to experiment.name, project_experiment_path(@project, experiment),
                            class: "hover:text-primary-600 transition" %>
              </h3>

              <div class="flex items-center space-x-1 ml-2">
                <%= link_to edit_project_experiment_path(@project, experiment),
                            class: "text-gray-400 hover:text-primary-600 p-1 transition",
                            title: "Редактировать" do %>
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                  </svg>
                <% end %>

                <%= link_to project_experiment_path(@project, experiment),
                            data: {
                              turbo_method: :delete,
                              turbo_confirm: "Удалить эксперимент «#{experiment.name}»? Это действие необратимо."
                            },
                            class: "text-gray-400 hover:text-red-600 p-1 transition",
                            title: "Удалить" do %>
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                <% end %>
              </div>
            </div>

            <% if experiment.description.present? %>
              <p class="text-gray-600 text-sm mb-4 line-clamp-2"><%= experiment.description %></p>
            <% end %>

            <div class="flex items-center justify-between text-xs text-gray-500 mt-4">
<!--              <span class="flex items-center">-->
<!--                <svg class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">-->
<!--                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />-->
<!--                </svg>-->
                <%= pluralize(experiment.json_results_count, 'результат', 'результата', 'результатов') %>
<!--              </span>-->
              <span><%= ru_time_ago_in_words(experiment.created_at) %></span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-lg shadow p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
        <h3 class="mt-2 text-sm font-semibold text-gray-900">Нет экспериментов</h3>
        <p class="mt-1 text-sm text-gray-500">Создайте первый эксперимент для этого проекта</p>
        <div class="mt-6">
          <%= link_to 'Создать эксперимент', new_project_experiment_path(@project),
                      class: 'inline-flex items-center px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition font-medium' %>
        </div>
      </div>
    <% end %>
  </div>
</div>
