<div class="min-h-[60vh] flex flex-col items-center justify-center py-12">
  <div class="text-center">
    <%= icon %>
    <h3 class="mt-2 text-sm font-semibold text-gray-900"><%= title %></h3>
    <p class="mt-1 text-sm text-gray-500"><%= description %></p>
    <% if defined?(action_path) && action_path.present? %>
      <div class="mt-6">
        <%= link_to action_text, action_path,
                    class: "inline-flex items-center rounded-md bg-primary-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-primary-700 transition" %>
      </div>
    <% end %>
  </div>
</div>
