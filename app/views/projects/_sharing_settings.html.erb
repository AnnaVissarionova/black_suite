<% project = local_assigns[:project] || @project %>
<% if policy(project).update? %>
  <button onclick="openProjectShareModal_<%= project.id %>()"
          class="inline-flex items-center justify-center px-3 py-2 bg-white border border-gray-200 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 hover:border-primary-300 transition-all shadow-sm">
    <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
    </svg>
    Поделиться
  </button>

  <!-- модальное окно для шаринга проекта -->
  <div id="projectShareModal_<%= project.id %>" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-2xl max-w-xl w-full max-h-[90vh] overflow-y-auto" onclick="event.stopPropagation()">
      <div class="flex items-center justify-between p-6 border-b border-gray-200">
        <h3 class="text-lg font-semibold text-gray-800 flex items-center">
          <svg class="h-5 w-5 mr-2 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
          </svg>
          Поделиться проектом
        </h3>
        <button onclick="closeProjectShareModal_<%= project.id %>()" class="text-gray-400 hover:text-gray-600 transition">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div id="project-share-content-<%= project.id %>" class="p-6">
      </div>
    </div>
  </div>

  <script>
      (function() {
          const projectId = <%= project.id %>;
          const csrfToken = document.querySelector('meta[name="csrf-token"]').content;
          const sharingPath = '<%= sharing_project_path(project) %>';
          const updateSharingPath = '<%= update_sharing_project_path(project) %>';
          const regenerateTokenPath = '<%= regenerate_token_project_path(project) %>';

          window['openProjectShareModal_' + projectId] = function() {
              document.getElementById('projectShareModal_' + projectId).classList.remove('hidden');
              document.body.style.overflow = 'hidden';
              loadProjectSharingContent();
          };

          window['closeProjectShareModal_' + projectId] = function() {
              document.getElementById('projectShareModal_' + projectId).classList.add('hidden');
              document.body.style.overflow = 'auto';
          };

          function loadProjectSharingContent() {
              const contentDiv = document.getElementById('project-share-content-' + projectId);
              contentDiv.innerHTML = `
                  <div class="text-center py-8">
                      <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-500 mb-3"></div>
                      <p class="text-gray-500">Загрузка...</p>
                  </div>
              `;

              fetch(sharingPath, {
                  headers: {
                      'Accept': 'application/json',
                      'X-CSRF-Token': csrfToken
                  }
              })
              .then(response => response.json())
              .then(data => {
                  updateProjectSharingContent(data);
              })
              .catch(error => {
                  console.error('Ошибка загрузки:', error);
                  contentDiv.innerHTML = `
                  <div class="text-center py-8">
                      <svg class="h-12 w-12 text-red-400 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <p class="text-gray-700">Ошибка загрузки данных</p>
                      <button onclick="loadProjectSharingContent()" class="mt-4 px-4 py-2 bg-primary-500 text-white rounded-lg hover:bg-primary-600">
                          Повторить
                      </button>
                  </div>
              `;
              });
          }

          function updateProjectSharingContent(data) {
              const contentDiv = document.getElementById('project-share-content-' + projectId);

              if (data.shared && data.share_mode === 'view' && data.share_token) {
                  contentDiv.innerHTML = `
                <div class="space-y-6">
                    <div class="p-4 bg-green-50 border border-green-200 rounded-lg">
                        <div class="flex items-start justify-between mb-3">
                            <div class="flex items-center">
                                <svg class="h-5 w-5 text-green-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <span class="font-medium text-green-800">Доступ по ссылке активен</span>
                            </div>
                            <button onclick="disableProjectSharing_${projectId}()" class="text-sm text-red-500 hover:text-red-700 font-medium">
                                Отключить
                            </button>
                        </div>

                        <p class="text-sm text-gray-600 mb-3">
                            Пользователи с этой ссылкой могут <strong>просматривать</strong> проект и все эксперименты.
                        </p>

                        <label class="block text-sm font-medium text-gray-700 mb-2">Ссылка для просмотра:</label>
                        <div class="flex items-center space-x-2">
                            <input type="text"
                                   value="${data.share_url || ''}"
                                   readonly
                                   id="project-share-link-${projectId}"
                                   class="flex-1 px-3 py-2 border border-gray-200 rounded-lg bg-white text-sm font-mono">
                            <button type="button"
                                    onclick="copyProjectShareLink_${projectId}()"
                                    class="px-4 py-2 bg-primary-500 text-white rounded-lg hover:bg-primary-600 transition font-medium text-sm whitespace-nowrap">
                                <svg class="h-4 w-4 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                                </svg>
                            </button>
                        </div>

                        <div class="mt-3 flex items-center justify-between">
                            <button onclick="regenerateProjectToken_${projectId}()"
                                    class="text-sm text-gray-500 hover:text-gray-700 flex items-center">
                                <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                                </svg>
                                Обновить ссылку
                            </button>

                            <span id="project-copy-success-${projectId}" class="hidden text-sm text-green-600 font-medium">
                                Скопировано!
                            </span>
                        </div>
                    </div>
                </div>


                <!--<div class="flex items-center justify-end gap-3 pt-6 mt-6 border-t border-gray-100">-->
                 <!--   <button type="button"-->
                  <!--          onclick="closeProjectShareModal_${projectId}()"-->
                  <!--          class="px-4 py-2 border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 transition font-medium">-->
                    <!--    Закрыть-->
                  <!--  </button>-->
              <!--  </div>-->
            `;
              } else {
                  contentDiv.innerHTML = `
                <div class="space-y-6">
                    <div class="p-4 bg-gray-50 border border-gray-200 rounded-lg">
                        <div class="flex items-start mb-4">
                            <svg class="h-6 w-6 text-gray-400 mr-3 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <div>
                                <p class="text-sm text-gray-700 font-medium mb-2">
                                    Создайте ссылку для общего доступа к проекту
                                </p>
                                <p class="text-xs text-gray-500">
                                    Пользователи с ссылкой смогут <strong>просматривать</strong> проект и все эксперименты.
                                </p>
                            </div>
                        </div>

                        <button onclick="enableProjectSharing_${projectId}()"
                                class="w-full px-4 py-2 bg-primary-500 text-white rounded-lg hover:bg-primary-600 transition font-medium">
                            Создать ссылку для доступа
                        </button>
                    </div>
                </div>

                <!--<div class="flex items-center justify-end gap-3 pt-6 mt-6 border-t border-gray-100">-->
                    <!--<button type="button"-->
                        <!--    onclick="closeProjectShareModal_${projectId}()"-->
                        <!--    class="px-4 py-2 border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 transition font-medium">-->
                      <!--  Закрыть-->
                   <!-- </button>-->
                <!--</div>-->
            `;
              }
          }

          window['enableProjectSharing_' + projectId] = function() {
              const contentDiv = document.getElementById('project-share-content-' + projectId);
              contentDiv.innerHTML = `
                <div class="text-center py-8">
                    <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-500 mb-3"></div>
                    <p class="text-gray-500">Создание ссылки...</p>
                </div>
              `;

              fetch(updateSharingPath, {
                  method: 'PATCH',
                  headers: {
                      'X-CSRF-Token': csrfToken,
                      'Accept': 'application/json',
                      'Content-Type': 'application/json'
                  },
                  body: JSON.stringify({ share_mode: 'view' })
              })
              .then(response => response.json())
              .then(data => {
                  if (data.success) {
                      loadProjectSharingContent();
                  } else {
                      alert(data.error || 'Ошибка при создании ссылки');
                      loadProjectSharingContent();
                  }
              })
              .catch(error => {
                  console.error('Enable sharing error:', error);
                  alert('Ошибка при создании ссылки: ' + error.message);
                  loadProjectSharingContent();
              });
          };

          window['disableProjectSharing_' + projectId] = function() {
              if (!confirm('Отключить доступ по ссылке?')) return;

              const contentDiv = document.getElementById('project-share-content-' + projectId);
              contentDiv.innerHTML = `
                <div class="text-center py-8">
                    <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-500 mb-3"></div>
                    <p class="text-gray-500">Отключение доступа...</p>
                </div>
              `;

              fetch(updateSharingPath, {
                  method: 'PATCH',
                  headers: {
                      'X-CSRF-Token': csrfToken,
                      'Accept': 'application/json',
                      'Content-Type': 'application/json'
                  },
                  body: JSON.stringify({ share_mode: 'private' })
              })
              .then(response => response.json())
              .then(data => {
                  if (data.success) {
                      loadProjectSharingContent();
                  } else {
                      alert(data.error || 'Ошибка при отключении доступа');
                      loadProjectSharingContent();
                  }
              })
              .catch(error => {
                  console.error('Disable sharing error:', error);
                  alert('Ошибка при отключении доступа: ' + error.message);
                  loadProjectSharingContent();
              });
          };

          window['regenerateProjectToken_' + projectId] = function() {
              if (!confirm('Текущая ссылка перестанет работать. Создать новую?')) return;

              const contentDiv = document.getElementById('project-share-content-' + projectId);
              contentDiv.innerHTML = `
                <div class="text-center py-8">
                    <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-500 mb-3"></div>
                    <p class="text-gray-500">Обновление ссылки...</p>
                </div>
              `;

              fetch(regenerateTokenPath, {
                  method: 'POST',
                  headers: {
                      'X-CSRF-Token': csrfToken,
                      'Accept': 'application/json'
                  }
              })
              .then(response => response.json())
              .then(data => {
                  if (data.success) {
                      loadProjectSharingContent();
                  } else {
                      alert(data.error || 'Ошибка при обновлении ссылки');
                      loadProjectSharingContent();
                  }
              })
              .catch(error => {
                  console.error('Regenerate token error:', error);
                  alert('Ошибка при обновлении ссылки: ' + error.message);
                  loadProjectSharingContent();
              });
          };

          window['copyProjectShareLink_' + projectId] = function() {
              const input = document.getElementById('project-share-link-' + projectId);
              if (!input) return;

              input.select();
              input.setSelectionRange(0, 99999);

              try {
                  document.execCommand('copy');
                  const successMsg = document.getElementById('project-copy-success-' + projectId);
                  if (successMsg) {
                      successMsg.classList.remove('hidden');
                      setTimeout(() => successMsg.classList.add('hidden'), 2000);
                  }
              } catch (err) {
                  console.error('Ошибка копирования:', err);
                  alert('Не удалось скопировать ссылку');
              }
          };

          document.getElementById('projectShareModal_' + projectId)?.addEventListener('click', function(e) {
              if (e.target === this) {
                  window['closeProjectShareModal_' + projectId]();
              }
          });
      })();
  </script>
<% end %>
