<div class="bg-white rounded-lg shadow hover:shadow-lg transition-all p-6 border-l-4 border-primary-500">
  <div class="flex justify-between items-start mb-2">
    <h3 class="text-lg font-semibold text-gray-900 flex-1">
      <%= link_to experiment.name, experiment_view_project_path(project, experiment_id: experiment.id),
                  class: "hover:text-primary-600 transition" %>
    </h3>

    <div class="flex items-center space-x-1 ml-2">
      <%= link_to edit_project_experiment_path(project, experiment),
                  class: "text-gray-400 hover:text-primary-600 p-1 transition",
                  title: "Редактировать" do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
      <% end %>

      <%= link_to project_experiment_path(project, experiment),
                  data: {
                    turbo_method: :delete,
                    turbo_confirm: "Удалить эксперимент «#{experiment.name}»? Это действие необратимо."
                  },
                  class: "text-gray-400 hover:text-red-600 p-1 transition",
                  title: "Удалить" do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
      <% end %>
    </div>
  </div>

  <% if experiment.description.present? %>
    <p class="text-gray-600 text-sm mb-4 line-clamp-2"><%= experiment.description %></p>
  <% end %>

  <div class="flex items-center justify-between text-xs text-gray-500 mt-4">
    <span><%= ru_time_ago_in_words(experiment.created_at) %></span>
  </div>
</div>
