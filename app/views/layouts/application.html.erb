<!DOCTYPE html>
<html lang="ru">
<head>
  <title>BlackSuite</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>

  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.plot.ly/plotly-2.24.1.min.js"></script>

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: {
                50: '#f8f7fc',
                100: '#f0eef9',
                200: '#e4e0f4',
                300: '#d0c9eb',
                400: '#b5aad9',
                500: '#9a8bc7',
                600: '#7f6bb0',
                700: '#6b5699',
                800: '#574680',
                900: '#473a69',
            },
            secondary: {
                100: '#eef1f9',
                200: '#e0e6f4',
                400: '#aab6d9',
                600: '#6b79b0',
                700: '#566299',
                800: '#465280',
            }
          }
        }
      }
    }
  </script>

  <style>
    html, body {
      height: 100%;
    }
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .plotly-plot {
      width: 100%;
      min-height: 400px;
    }
    .plotly-plot .modebar {
      opacity: 0.5;
      transition: opacity 0.2s;
    }
    .plotly-plot:hover .modebar {
      opacity: 1;
    }
    @media (max-width: 768px) {
      .plotly-plot {
        min-height: 300px;
      }
    }
  </style>
</head>

<body class="bg-gray-50 min-h-screen flex flex-col">
  <% if user_signed_in? && !devise_controller? %>
    <%= render 'layouts/navbar' %>
  <% end %>

  <%= render 'shared/flash' %>

  <main class="flex-grow <%= user_signed_in? && !devise_controller? ? 'pt-16' : '' %>">
    <%= yield %>
  </main>

  <% if user_signed_in? && !devise_controller? %>
    <% cache ["footer", current_user.id] do %>
      <footer class="bg-gradient-to-r from-secondary-600 to-primary-600 text-white py-4 mt-auto">
        <div class="container mx-auto px-4 text-center text-sm">
          <p>BlackSuite <%= Time.now.year %></p>
        </div>
      </footer>
    <% end %>
  <% end %>
</body>
</html>
