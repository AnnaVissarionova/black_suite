<% experiment = local_assigns[:experiment] || @experiment %>
<% project = local_assigns[:project] || @project %>
<% if policy(experiment).manage_sharing? %>
  <button onclick="openExperimentShareModal_<%= experiment.id %>()"
          class="inline-flex items-center justify-center px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-xs font-medium text-gray-600 hover:bg-gray-50 hover:border-primary-300 transition-all">
    <svg class="h-3.5 w-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
    </svg>
    Поделиться
  </button>

  <div id="experimentShareModal_<%= experiment.id %>" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-2xl max-w-xl w-full max-h-[90vh] overflow-y-auto" onclick="event.stopPropagation()">
      <div class="flex items-center justify-between p-6 border-b border-gray-200">
        <h3 class="text-lg font-semibold text-gray-800 flex items-center">
          <svg class="h-5 w-5 mr-2 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
          </svg>
          Поделиться экспериментом
        </h3>
        <button onclick="closeExperimentShareModal_<%= experiment.id %>()" class="text-gray-400 hover:text-gray-600 transition">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div id="experiment-share-content-<%= experiment.id %>" class="p-6">
      </div>
    </div>
  </div>

  <script>
      (function() {
          const experimentId = <%= experiment.id %>;
          const csrfToken = document.querySelector('meta[name="csrf-token"]').content;
          const sharingPath = '<%= sharing_project_experiment_path(project, experiment) %>';
          const updateSharingTruePath = '<%= update_sharing_project_experiment_path(project, experiment, enable_sharing: true) %>';
          const updateSharingFalsePath = '<%= update_sharing_project_experiment_path(project, experiment, enable_sharing: false) %>';
          const regenerateTokenPath = '<%= regenerate_token_project_experiment_path(project, experiment) %>';

          window['openExperimentShareModal_' + experimentId] = function() {
              document.getElementById('experimentShareModal_' + experimentId).classList.remove('hidden');
              document.body.style.overflow = 'hidden';
              loadSharingContent();
          };

          window['closeExperimentShareModal_' + experimentId] = function() {
              document.getElementById('experimentShareModal_' + experimentId).classList.add('hidden');
              document.body.style.overflow = 'auto';
          };

          function loadSharingContent() {
              const contentDiv = document.getElementById('experiment-share-content-' + experimentId);
              contentDiv.innerHTML = `
                  <div class="text-center py-8">
                      <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-500 mb-3"></div>
                      <p class="text-gray-500">Загрузка...</p>
                  </div>
              `;

              fetch(sharingPath, {
                  headers: {
                      'Accept': 'application/json',
                      'X-CSRF-Token': csrfToken
                  }
              })
              .then(response => response.json())
              .then(data => {
                  updateSharingContent(data);
              })
              .catch(error => {
                  console.error('Ошибка загрузки:', error);
                  contentDiv.innerHTML = `
                  <div class="text-center py-8">
                      <svg class="h-12 w-12 text-red-400 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <p class="text-gray-700">Ошибка загрузки данных</p>
                  </div>
              `;
              });
          }

          function updateSharingContent(data) {
              const contentDiv = document.getElementById('experiment-share-content-' + experimentId);

              if (data.shared && data.share_token) {
                  contentDiv.innerHTML = `
                  <div class="space-y-6">
                      <div class="p-4 bg-green-50 border border-green-200 rounded-lg">
                          <div class="flex items-start justify-between mb-3">
                              <div class="flex items-center">
                                  <svg class="h-5 w-5 text-green-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                  </svg>
                                  <span class="font-medium text-green-800">Доступ по ссылке активен</span>
                              </div>
                              <button onclick="disableSharing_${experimentId}()" class="text-sm text-red-500 hover:text-red-700 font-medium">
                                  Отключить
                              </button>
                          </div>

                          <p class="text-sm text-gray-600 mb-3">
                              Пользователи с этой ссылкой могут <strong>просматривать</strong> данные эксперимента.
                          </p>

                          <label class="block text-sm font-medium text-gray-700 mb-2">Ссылка для просмотра:</label>
                          <div class="flex items-center space-x-2">
                              <input type="text"
                                     value="${data.share_url}"
                                     readonly
                                     id="experiment-share-link-${experimentId}"
                                     class="flex-1 px-3 py-2 border border-gray-200 rounded-lg bg-white text-sm font-mono">
                              <button type="button"
                                      onclick="copyShareLink_${experimentId}()"
                                      class="px-4 py-2 bg-primary-500 text-white rounded-lg hover:bg-primary-600 transition font-medium text-sm whitespace-nowrap">
                                  <svg class="h-4 w-4 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                                  </svg>
                              </button>
                          </div>

                          <div class="mt-3 flex items-center justify-between">
                              <button onclick="regenerateToken_${experimentId}()"
                                      class="text-sm text-gray-500 hover:text-gray-700 flex items-center">
                                  <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                                  </svg>
                                  Обновить ссылку
                              </button>

                              <span id="copy-success-${experimentId}" class="hidden text-sm text-green-600 font-medium">
                                  Скопировано!
                              </span>
                          </div>
                      </div>
                  </div>

                  <div class="flex items-center justify-end gap-3 pt-6 mt-6 border-t border-gray-100">
                      <button type="button"
                              onclick="closeExperimentShareModal_${experimentId}()"
                              class="px-4 py-2 border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 transition font-medium">
                          Закрыть
                      </button>
                  </div>
              `;
              } else {
                  contentDiv.innerHTML = `
                  <div class="space-y-6">
                      <div class="p-4 bg-gray-50 border border-gray-200 rounded-lg">
                          <div class="flex items-start mb-4">
                              <svg class="h-6 w-6 text-gray-400 mr-3 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                              </svg>
                              <div>
                                  <p class="text-sm text-gray-700 font-medium mb-2">
                                      Включите доступ по ссылке, чтобы поделиться этим экспериментом
                                  </p>
                                  <p class="text-xs text-gray-500">
                                      Пользователи с ссылкой смогут <strong>только просматривать</strong> данные эксперимента.
                                  </p>
                              </div>
                          </div>

                          <button onclick="enableSharing_${experimentId}()"
                                  class="w-full px-4 py-2 bg-primary-500 text-white rounded-lg hover:bg-primary-600 transition font-medium">
                              Включить доступ по ссылке
                          </button>
                      </div>
                  </div>

                  <div class="flex items-center justify-end gap-3 pt-6 mt-6 border-t border-gray-100">
                      <button type="button"
                              onclick="closeExperimentShareModal_${experimentId}()"
                              class="px-4 py-2 border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 transition font-medium">
                          Закрыть
                      </button>
                  </div>
              `;
              }
          }

          window['enableSharing_' + experimentId] = function() {
              const contentDiv = document.getElementById('experiment-share-content-' + experimentId);
              contentDiv.innerHTML = `
                  <div class="text-center py-8">
                      <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-500 mb-3"></div>
                      <p class="text-gray-500">Включение доступа...</p>
                  </div>
              `;

              fetch(updateSharingTruePath, {
                  method: 'PATCH',
                  headers: {
                      'X-CSRF-Token': csrfToken,
                      'Accept': 'application/json'
                  }
              })
              .then(response => response.json())
              .then(data => {
                  loadSharingContent();
              })
              .catch(error => {
                  console.error('Ошибка:', error);
                  alert('Ошибка при включении доступа');
                  loadSharingContent();
              });
          };

          window['disableSharing_' + experimentId] = function() {
              if (!confirm('Отключить доступ по ссылке?')) return;

              const contentDiv = document.getElementById('experiment-share-content-' + experimentId);
              contentDiv.innerHTML = `
                  <div class="text-center py-8">
                      <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-500 mb-3"></div>
                      <p class="text-gray-500">Отключение доступа...</p>
                  </div>
              `;

              fetch(updateSharingFalsePath, {
                  method: 'PATCH',
                  headers: {
                      'X-CSRF-Token': csrfToken,
                      'Accept': 'application/json'
                  }
              })
              .then(response => response.json())
              .then(data => {
                  loadSharingContent();
              })
              .catch(error => {
                  console.error('Ошибка:', error);
                  alert('Ошибка при отключении доступа');
                  loadSharingContent();
              });
          };

          window['regenerateToken_' + experimentId] = function() {
              if (!confirm('Текущая ссылка перестанет работать. Создать новую?')) return;

              const contentDiv = document.getElementById('experiment-share-content-' + experimentId);
              contentDiv.innerHTML = `
                  <div class="text-center py-8">
                      <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-500 mb-3"></div>
                      <p class="text-gray-500">Обновление ссылки...</p>
                  </div>
              `;

              fetch(regenerateTokenPath, {
                  method: 'POST',
                  headers: {
                      'X-CSRF-Token': csrfToken,
                      'Accept': 'application/json'
                  }
              })
              .then(response => response.json())
              .then(data => {
                  loadSharingContent();
              })
              .catch(error => {
                  console.error('Ошибка:', error);
                  alert('Ошибка при обновлении ссылки');
                  loadSharingContent();
              });
          };

          window['copyShareLink_' + experimentId] = function() {
              const input = document.getElementById('experiment-share-link-' + experimentId);
              if (!input) return;

              input.select();
              input.setSelectionRange(0, 99999);

              try {
                  document.execCommand('copy');
                  const successMsg = document.getElementById('copy-success-' + experimentId);
                  if (successMsg) {
                      successMsg.classList.remove('hidden');
                      setTimeout(() => successMsg.classList.add('hidden'), 2000);
                  }
              } catch (err) {
                  console.error('Ошибка копирования:', err);
                  alert('Не удалось скопировать ссылку');
              }
          };

          document.getElementById('experimentShareModal_' + experimentId)?.addEventListener('click', function(e) {
              if (e.target === this) {
                  window['closeExperimentShareModal_' + experimentId]();
              }
          });
      })();
  </script>
<% end %>
