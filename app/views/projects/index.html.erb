<div class="py-10">
  <header>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-2xl font-bold text-gray-800">Все проекты</h1>
    </div>
  </header>

  <main>
    <div class="mx-auto max-w-7xl sm:px-6 lg:px-8">
      <% if @projects.any? %>
        <div class="px-4 py-8 sm:px-0">
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            <%= render partial: 'projects/project_card', collection: @projects, as: :project %>
          </div>
        </div>
      <% else %>
        <div class="min-h-[60vh] flex flex-col items-center justify-center py-12">
          <div class="text-center">
            <svg class="mx-auto h-16 w-16 text-gray-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
            </svg>
            <h3 class="mt-4 text-lg font-medium text-gray-600">Нет проектов</h3>
            <p class="mt-1 text-sm text-gray-400">Создайте свой первый проект для начала работы</p>
            <div class="mt-6">
              <%= link_to 'Создать проект', new_project_path,
                          class: "inline-flex items-center rounded-lg bg-primary-500 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-primary-600 transition" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </main>
</div>
