<div class="bg-white rounded-xl shadow p-6 mb-8">
  <h3 class="font-medium text-gray-900 mb-4">Выбор параметров для визуализации</h3>
  <%= form_tag experiment_view_project_path(experiment.project, experiment_id: experiment.id), method: :get,
               id: "params-form",
               class: "grid grid-cols-1 md:grid-cols-2 gap-4" do %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Параметр X:</label>
      <select name="param_x"
              onchange="document.getElementById('params-form').submit()"
              class="w-full rounded-lg border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500">
        <% variables.each_with_index do |var, index| %>
          <option value="<%= index %>" <%= 'selected' if index == selected_x %>><%= var %></option>
        <% end %>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Параметр Y:</label>
      <select name="param_y"
              onchange="document.getElementById('params-form').submit()"
              class="w-full rounded-lg border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500">
        <% variables.each_with_index do |var, index| %>
          <option value="<%= index %>" <%= 'selected' if index == selected_y %>><%= var %></option>
        <% end %>
      </select>
    </div>
  <% end %>
</div>
