<div class="min-h-screen bg-gray-50">
  <div class="mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8 py-6">
    <nav class="mb-6 text-sm">
      <%= link_to 'Проекты', projects_path, class: 'text-primary-600 hover:text-primary-700' %> ›
      <span class="text-gray-600 font-medium"><%= @project.name %></span>
    </nav>


    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
      <div>
       <span class="items-center p-1 rounded text-xs font-mono bg-gray-100 text-gray-400">
         ID <%= @project.id %>
       </span>
        <h1 class="text-2xl font-bold text-gray-800"><%= @project.name %></h1>
        <% if @project.description.present? %>
          <p class="text-gray-500 mt-1 text-sm whitespace-pre-line"><%= @project.description %></p>
        <% end %>
      </div>

      <% if policy(@project).update? %>
        <div class="flex items-center gap-2">
          <%= render 'projects/sharing_settings', project: @project %>

          <%= link_to edit_project_path(@project),
                      class: 'inline-flex items-center px-3 py-2 bg-white border border-gray-200 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 hover:border-primary-300 transition-all shadow-sm' do %>
            <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            Редактировать
          <% end %>

          <%= link_to project_path(@project),
                      data: {
                        turbo_method: :delete,
                        turbo_confirm: "Удалить проект «#{@project.name}»? Все эксперименты будут удалены. Это действие необратимо."
                      },
                      class: 'inline-flex items-center px-3 py-2 bg-white border border-gray-200 rounded-lg text-sm font-medium text-red-500 hover:bg-red-50 hover:border-red-300 transition-all shadow-sm' do %>
            <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
            Удалить
          <% end %>

          <%= link_to new_project_experiment_path(@project),
                      class: 'inline-flex items-center px-4 py-2 bg-primary-500 text-white rounded-lg text-sm font-medium hover:bg-primary-600 transition-all shadow-sm' do %>
            <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Новый эксперимент
          <% end %>
        </div>
      <% end %>
    </div>

    <% if @experiments.any? %>
      <div class="flex flex-col lg:flex-row gap-6">
        <div class="lg:w-1/3 xl:w-1/4">
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-4 py-3 bg-gray-50 border-b border-gray-100">
              <h2 class="text-sm font-semibold text-gray-700">Эксперименты</h2>
              <p class="text-xs text-gray-400 mt-0.5"><%= @project.experiments_count %> шт.</p>
            </div>
            <div class="divide-y divide-gray-50 max-h-[calc(100vh-280px)] overflow-y-auto">
              <% @experiments.each do |experiment| %>
                <div class="experiment-list-item px-4 py-3 hover:bg-primary-50 cursor-pointer transition-colors"
                     data-experiment-id="<%= experiment.id %>"
                     data-project-id="<%= @project.id %>">
                  <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                      <h3 class="text-sm font-medium text-gray-800 truncate"><%= experiment.name %></h3>
                      <% if experiment.description.present? %>
                        <p class="text-xs text-gray-400 truncate mt-0.5 text-sm whitespace-pre-line"><%= experiment.description %></p>
                      <% end %>
                    </div>
                    <% if policy(@project).update? %>
                      <div class="flex items-center space-x-1 ml-2 experiment-actions">
                        <%= render partial: 'experiments/experiment_share_button',
                                   locals: { experiment: experiment, project: @project } %>
                        <%= link_to edit_project_experiment_path(@project, experiment),
                                    class: "text-gray-300 hover:text-primary-500 p-1 transition",
                                    title: "Редактировать" do %>
                          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                          </svg>
                        <% end %>
                        <%= link_to project_experiment_path(@project, experiment),
                                    data: {
                                      turbo_method: :delete,
                                      turbo_confirm: "Удалить эксперимент «#{experiment.name}»?"
                                    },
                                    class: "text-gray-300 hover:text-red-500 p-1 transition",
                                    title: "Удалить" do %>
                          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                          </svg>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                  <div class="text-xs text-gray-300 mt-1"><%= ru_time_ago_in_words(experiment.created_at) %></div>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <div class="lg:w-2/3 xl:w-3/4">
          <div id="experiment-content"
               class="bg-white rounded-xl shadow-sm border border-gray-100 min-h-[400px] flex items-center justify-center">
            <div class="text-center py-12 px-4">
              <svg class="mx-auto h-16 w-16 text-gray-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
              <h3 class="mt-4 text-lg font-medium text-gray-400">Выберите эксперимент</h3>
              <p class="mt-1 text-sm text-gray-300">Нажмите на эксперимент слева для просмотра деталей</p>
            </div>
          </div>
        </div>
      </div>
    <% else %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center">
        <svg class="mx-auto h-16 w-16 text-gray-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
        <h3 class="mt-4 text-lg font-medium text-gray-600">Нет экспериментов</h3>
        <p class="mt-1 text-sm text-gray-400">Создайте первый эксперимент для этого проекта</p>
        <div class="mt-6">
          <%= link_to 'Создать эксперимент', new_project_experiment_path(@project),
                      class: 'inline-flex items-center px-4 py-2 bg-primary-500 text-white rounded-lg hover:bg-primary-600 transition font-medium' %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
    document.addEventListener('turbo:load', function() {
        const experimentItems = document.querySelectorAll('.experiment-list-item');
        const contentArea = document.getElementById('experiment-content');

        const isSharedProject = window.location.pathname.includes('/shared/project/');
        const isSharedExperiment = window.location.pathname.includes('/shared/experiment/');
        let shareToken = null;

        if (isSharedProject || isSharedExperiment) {
            const matches = window.location.pathname.match(/\/shared\/(?:project|experiment)\/([^\/?#]+)/);
            if (matches) {
                shareToken = matches[1];
            }
            console.log('Shared mode:', isSharedProject ? 'project' : 'experiment', 'Token:', shareToken);
        }

        if (isSharedExperiment) {
            console.log('Shared experiment page - no AJAX needed');
            return;
        }

        experimentItems.forEach(item => {
            item.addEventListener('click', function(e) {
                if (e.target.closest('.experiment-actions a')) return;

                const experimentId = this.dataset.experimentId;
                const projectId = this.dataset.projectId;

                let url;

                if (isSharedProject && shareToken) {
                    url = window.location.origin + '/shared/project/' + shareToken  + '/experiment/' + experimentId + '?partial=true';
                    console.log('Shared PROJECT URL (goes to projects#show_experiment):', url);
                } else if (projectId) {
                    url = window.location.origin + '/projects/' + projectId + '/experiment/' + experimentId + '?partial=true';
                    console.log('Regular URL:', url);
                } else {
                    console.error('No valid mode detected');
                    return;
                }

                experimentItems.forEach(el => {
                    el.classList.remove('bg-primary-50', 'border-l-4', 'border-primary-500');
                });

                this.classList.add('bg-primary-50', 'border-l-4', 'border-primary-500');

                contentArea.innerHTML = `
          <div class="flex items-center justify-center py-12">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary-500"></div>
            <span class="ml-3 text-gray-500">Загрузка...</span>
          </div>
        `;

                fetch(url, {
                    headers: {
                        'Accept': 'text/html',
                        'X-Requested-With': 'XMLHttpRequest',
                        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
                    }
                })
                    .then(response => {
                        if (!response.ok) throw new Error('Network response was not ok');
                        return response.text();
                    })
                    .then(html => {
                        contentArea.innerHTML = html;
                        contentArea.classList.remove('flex', 'items-center', 'justify-center');

                        if (typeof Plotly !== 'undefined') {
                            setTimeout(() => {
                                if (window.initExperimentPlots) {
                                    window.initExperimentPlots();
                                }
                            }, 100);
                        }
                    })
                    .catch(error => {
                        console.error('Error loading experiment:', error);
                        contentArea.innerHTML = `
              <div class="text-center py-12 text-red-500">
                <p>Ошибка загрузки эксперимента</p>
                <p class="text-sm mt-2">${error.message}</p>
              </div>
            `;
                    });
            });
        });
    });
</script>
