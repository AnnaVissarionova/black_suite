<div class="bg-white rounded-lg shadow hover:shadow-lg transition-all p-6 border-t-4 border-primary-500 cursor-pointer group">
  <%= link_to project, class: "block no-underline" do %>
    <div class="flex justify-between items-start mb-4">
      <div class="flex-1">
        <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-blue-600">
          <%= project.name %>
        </h3>
        <% if project.description.present? %>
          <p class="text-gray-600 text-sm mb-3 line-clamp-2"><%= project.description %></p>
        <% end %>
      </div>

      <div class="flex items-center space-x-2" onclick="event.preventDefault();">
        <%= link_to edit_project_path(project),
                    class: "text-gray-400 hover:text-blue-600 p-1 z-10 relative" do %>
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
        <% end %>

        <%= link_to project_path(project),
                    data: {
                      turbo_method: :delete,
                      turbo_confirm: "Удалить проект '#{project.name}'? Отменить изменения не получится."
                    },
                    class: "text-gray-400 hover:text-red-600 p-1 z-10 relative" do %>
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="flex justify-between items-center text-xs text-gray-500">
    <div class="flex items-center space-x-4">
      <span class="flex items-center">
        <svg class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
        <%= pluralize(project.experiments_count, 'эксперимент', 'экспериментов') %>
      </span>
    </div>
    <%= link_to 'Просмотр', project_experiments_path(project),
                class: "text-primary-600 hover:text-primary-700 text-sm font-medium transition z-10 relative" %>
  </div>
</div>
