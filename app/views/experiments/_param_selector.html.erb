<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-4" id="param-selector-<%= experiment.id %>">
  <h3 class="font-medium text-gray-700 mb-3 text-sm">Выбор параметров для визуализации</h3>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label class="block text-xs font-medium text-gray-600 mb-1">Параметр X:</label>
      <select id="standalone-param-x-<%= experiment.id %>"
              class="w-full rounded-lg border-gray-200 shadow-sm focus:border-primary-400 focus:ring-primary-400 text-sm">
        <% variables.each_with_index do |var, index| %>
          <option value="<%= index %>" <%= 'selected' if index == selected_x %>><%= var %></option>
        <% end %>
      </select>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-600 mb-1">Параметр Y:</label>
      <select id="standalone-param-y-<%= experiment.id %>"
              class="w-full rounded-lg border-gray-200 shadow-sm focus:border-primary-400 focus:ring-primary-400 text-sm">
        <% variables.each_with_index do |var, index| %>
          <option value="<%= index %>" <%= 'selected' if index == selected_y %>><%= var %></option>
        <% end %>
      </select>
    </div>
  </div>
</div>

<script>
  (function() {
    const experimentId = <%= experiment.id %>;
    const projectId = <%= experiment.project_id %>;
    
    const paramXSelect = document.getElementById('standalone-param-x-' + experimentId);
    const paramYSelect = document.getElementById('standalone-param-y-' + experimentId);
    
    function updateParams() {
      const paramX = paramXSelect ? paramXSelect.value : 0;
      const paramY = paramYSelect ? paramYSelect.value : 1;
      
      const url = new URL(window.location.href);
      url.searchParams.set('param_x', paramX);
      url.searchParams.set('param_y', paramY);
      window.location.href = url.toString();
    }
    
    if (paramXSelect) {
      paramXSelect.addEventListener('change', updateParams);
    }
    
    if (paramYSelect) {
      paramYSelect.addEventListener('change', updateParams);
    }
  })();
</script>
